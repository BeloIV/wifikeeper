ldap {
    server = "${FR_LDAP_HOST}"
    port = 389

    identity = "${FR_LDAP_BIND_DN}"
    password = "${FR_LDAP_BIND_PASS}"

    base_dn = "${FR_LDAP_BASE_DN}"

    sasl {
    }

    # Atribúty pre autentifikáciu
    update {
        control:Password-With-Header    += 'userPassword'
        control:NT-Password             := 'sambaNTPassword'
        reply:Tunnel-Type               := 'radiusTunnelType'
        reply:Tunnel-Medium-Type        := 'radiusTunnelMediumType'
        reply:Tunnel-Private-Group-Id   := 'radiusTunnelPrivateGroupId'
    }

    # Hľadanie používateľov
    user {
        base_dn = "ou=users,${FR_LDAP_BASE_DN}"
        filter = "(uid=%{%{Stripped-User-Name}:-%{User-Name}})"
        scope = 'sub'
    }

    # Hľadanie skupín
    group {
        base_dn = "ou=groups,${FR_LDAP_BASE_DN}"
        filter = "(objectClass=groupOfNames)"
        membership_attribute = 'memberOf'
        # Záložná metóda – hľadaj v member atribúte skupiny
        membership_filter = "(member=%{control:Ldap-UserDn})"
        cacheable_name = 'no'
        cacheable_dn = 'no'
    }

    # Atribúty pre jednorazové kľúče (radiusSimultaneousUse)
    options {
        chase_referrals = yes
        rebind = yes
        res_timeout = 10
        srv_timelimit = 3
        net_timeout = 1
        idle = 60
        probes = 3
        interval = 3
        ldap_debug = 0x0028
    }

    pool {
        start = 5
        min = 4
        max = 10
        spare = 3
        uses = 0
        retry_delay = 30
        lifetime = 0
        idle_timeout = 60
    }
}
