# VLAN policy — číta VLAN z radreply tabuľky (zapísanej Djangom pri set_user_group)
# Žiaden reštart FreeRADIUS nie je potrebný po zmene skupiny.

vlan_policy {
    update control {
        &Tmp-String-0 := "%{sql:SELECT value FROM radreply WHERE username = '%{User-Name}' AND attribute = 'Tunnel-Private-Group-Id' LIMIT 1}"
    }

    if (&control:Tmp-String-0 && &control:Tmp-String-0 != '') {
        update reply {
            Tunnel-Type             := VLAN
            Tunnel-Medium-Type      := IEEE-802
            Tunnel-Private-Group-Id := &control:Tmp-String-0
        }
    }
    else {
        update reply {
            Reply-Message := "Pristup odmietnuty: pouzivatel nie je clenom ziadnej povolenej skupiny"
        }
        reject
    }
}
