# VLAN policy — dynamická, číta z radreply cez sql modul v authorize.
# Nevyžaduje reštart FreeRADIUS po zmene skupín alebo používateľov.

vlan_policy {
    if (&reply:Tunnel-Private-Group-Id) {
        ok
    }
    else {
        update reply {
            Reply-Message := "Pristup odmietnuty: pouzivatel nie je clenom ziadnej povolenej skupiny"
        }
        reject
    }
}
