server default {

    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    # CoA – Change of Authorization (odpojenie usera)
    listen {
        type = coa
        ipaddr = *
        port = 3799
    }

    # ── Autentifikácia ────────────────────────────────────────────────────────
    authorize {
        filter_username
        preprocess
        chap
        mschap
        digest
        suffix
        device_limit_policy
        eap {
            ok = return
        }
        ldap
        if (ok || updated) {
            update control {
                Auth-Type := ldap
            }
        }
        sql
        expiration
        logintime
    }

    authenticate {
        Auth-Type ldap {
            ldap
        }
        Auth-Type MS-CHAP {
            mschap
        }
        eap
    }

    # ── Accounting ────────────────────────────────────────────────────────────
    preacct {
        preprocess
        acct_unique
        suffix
        files
    }

    accounting {
        detail
        sql
        exec
        attr_filter.accounting_response
    }

    # ── Post-Auth: VLAN + accounting ─────────────────────────────────────────
    post-auth {
        vlan_policy
        sql

        Post-Auth-Type REJECT {
            attr_filter.access_reject
            sql
        }
    }
}
