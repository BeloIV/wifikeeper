# =============================================================================
# wifi-manager – príklad environment premenných
# Skopíruj do .env a vyplň hodnoty
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=wifimanager
POSTGRES_USER=wifimanager
POSTGRES_PASSWORD=zmen_ma_silne_heslo

# ── Redis (len v produkcii) ───────────────────────────────────────────────────
REDIS_PASSWORD=zmen_ma_redis_heslo

# ── OpenLDAP ──────────────────────────────────────────────────────────────────
LDAP_DOMAIN=oratko.local
LDAP_BASE_DN=dc=oratko,dc=local
LDAP_ADMIN_PASSWORD=zmen_ma_ldap_admin
LDAP_CONFIG_PASSWORD=zmen_ma_ldap_config
# Heslo pre readonly LDAP účet (používa FreeRADIUS na čítanie)
LDAP_READONLY_PASSWORD=zmen_ma_ldap_readonly

# ── FreeRADIUS ────────────────────────────────────────────────────────────────
# Shared secret musí súhlasiť s UniFi Network → RADIUS klientom
RADIUS_SECRET=zmen_ma_radius_secret
# CoA (Disconnect-Request) secret – musí súhlasiť s NAS (UniFi AP)
RADIUS_COA_SECRET=zmen_ma_coa_secret

# ── Django ────────────────────────────────────────────────────────────────────
# Vygeneruj: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=vygeneruj_dlhy_nahodny_retazec
# Fernet key pre šifrovanie ldap_password v DB
# Generuj: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=vygeneruj_fernet_kluc
# Superadmin účet (vytvorí sa automaticky pri prvom docker compose up)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=zmen_ma_admin_heslo

# ── Brevo email ───────────────────────────────────────────────────────────────
# Odosielacia adresa
MAIL_FROM=wifi@salezianipresov.xyz
# Brevo SMTP relay – nájdeš na app.brevo.com → SMTP & API → SMTP
BREVO_SMTP_USER=tvoj_brevo_login_email
BREVO_SMTP_KEY=tvoj_brevo_smtp_api_key
# Brevo REST API kľúč – pre scripts/setup-brevo.sh (app.brevo.com → API Keys)
BREVO_API_KEY=tvoj_brevo_api_kluc_v3

# Email admina – kam chodia notifikácie o expirácii kľúčov
ADMIN_EMAIL=admin@oratko.sk

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_IP=1.2.3.4

# ── Doména (len pre produkciu) ────────────────────────────────────────────────
DOMAIN=salezianipresov.xyz

# ── Cloudflare DNS-01 (Let's Encrypt v produkcii) ────────────────────────────
# Vytvor API token na dash.cloudflare.com → My Profile → API Tokens
# Permissions: Zone:DNS:Edit, Zone:Zone:Read
CLOUDFLARE_API_TOKEN=tvoj_cloudflare_api_token

# ── UniFi Network Application (docker-compose.unifi.yml) ─────────────────────
UNIFI_MONGO_USER=unifi
UNIFI_MONGO_PASS=zmen_ma_unifi_mongo_heslo
