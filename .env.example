# =============================================================================
# wifi-manager – príklad environment premenných
# Skopíruj do .env a vyplň hodnoty
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=wifimanager
POSTGRES_USER=wifimanager
POSTGRES_PASSWORD=zmen_ma_silne_heslo

# ── Redis (len v produkcii) ───────────────────────────────────────────────────
REDIS_PASSWORD=zmen_ma_redis_heslo

# ── OpenLDAP ──────────────────────────────────────────────────────────────────
LDAP_DOMAIN=oratko.local
LDAP_BASE_DN=dc=oratko,dc=local
LDAP_ADMIN_PASSWORD=zmen_ma_ldap_admin
LDAP_CONFIG_PASSWORD=zmen_ma_ldap_config
# Heslo pre readonly LDAP účet (používa FreeRADIUS na čítanie)
LDAP_READONLY_PASSWORD=zmen_ma_ldap_readonly

# ── FreeRADIUS ────────────────────────────────────────────────────────────────
# Shared secret musí súhlasiť s UniFi Network → RADIUS klientom
RADIUS_SECRET=zmen_ma_radius_secret

# ── Django ────────────────────────────────────────────────────────────────────
# Vygeneruj: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=vygeneruj_dlhy_nahodny_retazec

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=wifi@example.com
EMAIL_PASSWORD=smtp_heslo
EMAIL_USE_TLS=True
# Email admina – kam chodia notifikácie o expirácii kľúčov
ADMIN_EMAIL=admin@example.com

# ── Doména (len pre produkciu) ────────────────────────────────────────────────
DOMAIN=wifi.oratko.sk

# ── Cloudflare DNS-01 (Let's Encrypt v produkcii) ────────────────────────────
# Vytvor API token na dash.cloudflare.com → My Profile → API Tokens
# Permissions: Zone:DNS:Edit, Zone:Zone:Read
CLOUDFLARE_API_TOKEN=tvoj_cloudflare_api_token
