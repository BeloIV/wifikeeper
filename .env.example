# =============================================================================
# wifi-manager – príklad environment premenných
# Skopíruj do .env a vyplň hodnoty
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=wifimanager
POSTGRES_USER=wifimanager
POSTGRES_PASSWORD=

# ── Redis (len v produkcii) ───────────────────────────────────────────────────
REDIS_PASSWORD=

# ── OpenLDAP ──────────────────────────────────────────────────────────────────
LDAP_DOMAIN=oratko.local
LDAP_BASE_DN=dc=oratko,dc=local
LDAP_ADMIN_PASSWORD=
LDAP_CONFIG_PASSWORD=
LDAP_READONLY_PASSWORD=

# ── FreeRADIUS ────────────────────────────────────────────────────────────────
# Shared secret musí súhlasiť s UniFi Network → RADIUS klientom
RADIUS_SECRET=
# CoA secret – musí súhlasiť s UniFi: Settings → RADIUS → CoA shared secret
RADIUS_COA_SECRET=

# ── Django ────────────────────────────────────────────────────────────────────
# Vygeneruj: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
# Fernet key pre šifrovanie ldap_password v DB
# Generuj: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# Superadmin účet (vytvorí sa automaticky pri prvom docker compose up)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=

# ── Brevo email ───────────────────────────────────────────────────────────────
# Odosielacia adresa
MAIL_FROM=
# Brevo SMTP relay – nájdeš na app.brevo.com → SMTP & API → SMTP
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
# Brevo REST API kľúč – pre scripts/setup-brevo.sh (app.brevo.com → API Keys)
BREVO_API_KEY=

# Email admina – kam chodia notifikácie o expirácii kľúčov
ADMIN_EMAIL=

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_IP=

# ── Doména (len pre produkciu) ────────────────────────────────────────────────
DOMAIN=

# ── Cloudflare DNS-01 (Let's Encrypt v produkcii) ────────────────────────────
# Vytvor API token na dash.cloudflare.com → My Profile → API Tokens
# Permissions: Zone:DNS:Edit, Zone:Zone:Read
CLOUDFLARE_API_TOKEN=

# ── UniFi Network Application ─────────────────────────────────────────────────
UNIFI_MONGO_USER=unifi
UNIFI_MONGO_PASS=
